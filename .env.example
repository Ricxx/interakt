# Copy to .env and adjust. .env is gitignored.

# App database (127.0.0.1, not "localhost", to avoid IPv6 ::1 hitting a local Postgres)
DATABASE_URL=postgres://ces:ces@127.0.0.1:5442/ces
# Identity vault (separate DB, separate creds — never store mappings in the app DB)
VAULT_DATABASE_URL=postgres://vault:vault@127.0.0.1:5443/vault

# Server
PORT=8080
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
NODE_ENV=development
# Public URL of the app — used to build invite links in emails.
APP_URL=http://localhost:5173

# Email (optional in dev — leave SMTP_HOST blank and emails print to the console).
# Works with any SMTP provider (Mailgun, Postmark, SES, ...). Mailgun example shown.
EMAIL_FROM=CES <no-reply@ces.local>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Object storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=ces
MINIO_SECRET_KEY=ces-secret
